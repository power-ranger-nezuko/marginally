# --- Core ---
NODE_ENV=development
PORT=4000
APP_SECRET=replace_with_random_string

# --- Database ---
DATABASE_URL=postgres://user:password@localhost:5432/marginly
REDIS_URL=redis://localhost:6379

# --- Auth ---
JWT_SECRET=replace_with_random_string

# --- Stripe (platform-level: used to bill YOUR customers) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Stripe Connect (used so customers connect THEIR Stripe accounts) ---
STRIPE_CONNECT_CLIENT_ID=

# --- Shopify ---
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_SCOPES=read_orders,read_customers

# --- QuickBooks / Xero (Module 4) ---
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=

# --- Email / SMS (Module 1 - Dunning) ---
POSTMARK_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# --- Shipping / Helpdesk connectors (Module 3 - Dispute Evidence) ---
SHIPPO_API_KEY=
ZENDESK_API_TOKEN=

# --- File storage ---
AWS_REGION=us-east-1
AWS_S3_BUCKET=marginly-invoices
# DO NOT add AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY here.
# Production: the ECS task IAM role provides credentials automatically.
# Local dev:  run `aws sso login` and let the SDK pick up the session.
# CI/CD:      use GitHub Actions OIDC (see infra/terraform/modules/iam/).

# --- Secrets manager ---
# In production all secrets above come from AWS Secrets Manager, not this file.
# Set USE_AWS_SECRETS_MANAGER=true and the app will load /marginly/prod/* at startup.
USE_AWS_SECRETS_MANAGER=false
